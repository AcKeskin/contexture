{
  "name": "@ackeskin/unity-mcp-server",
  "version": "0.1.0",
  "description": "TypeScript MCP server for the custom Unity MCP — bridges MCP clients to the Unity Editor C# package over local HTTP",
  "author": "AcKeskin (https://github.com/AcKeskin)",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "unity-mcp-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "smoke": "node scripts/smoke.mjs",
    "smoke:v2": "node scripts/smoke-v2.mjs",
    "clean": "rimraf build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0"
  }
}
